@startuml
left to right direction
skinparam packageStyle rectangle

actor "Laborantin" as Labo

package "Module Laboratoire (ERP Hospitalier)" {
  usecase "Consulter les demandes d'analyses" as UC1
  usecase "Enregistrer un prélèvement" as UC2
  usecase "Saisir les résultats d'analyses" as UC3
  usecase "Valider les résultats" as UC4
  usecase "Imprimer/Publier le rapport" as UC5
  usecase "Signaler une non-conformité\n(ex: échantillon dégradé)" as UC6
  usecase "Gérer les stocks de réactifs\net consommables" as UC7
}

Labo --> UC1
Labo --> UC2
Labo --> UC3
Labo --> UC4
Labo --> UC5
Labo --> UC6
Labo --> UC7

' Relations de dépendance (includes) pour montrer la logique du flux
UC2 ..> UC1 : <<include>>
UC3 ..> UC2 : <<include>>
UC4 ..> UC3 : <<include>>
UC5 ..> UC4 : <<include>>

@enduml